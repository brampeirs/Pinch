{
  "name": "pinch",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "import-supabase-types": "supabase gen types typescript --linked --schema public > ./src/app/models/database.types.ts"
